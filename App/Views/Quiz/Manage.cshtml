@model BLL.DTOs.QuizDTO
@{
    ViewData["Title"] = "Manage Quiz";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Manage Quiz</h1>
        <p class="text-muted mb-0">Course: <strong>@Model.CourseTitle</strong> · Pass mark: <strong>@Model.PassMark%</strong></p>
    </div>
    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<!-- Existing questions -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">Questions <span class="badge bg-secondary">@Model.Questions.Count</span></h5>
    </div>
    <div class="card-body">
        @if (!Model.Questions.Any())
        {
            <p class="text-muted text-center my-3">No questions yet. Add your first one below.</p>
        }
        else
        {
            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                var q = Model.Questions[i];
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="mb-0">Q@(i + 1). @q.QuestionText</h6>
                        <div class="d-flex gap-1">
                            <a asp-action="EditQuestion" asp-route-id="@q.Id" asp-route-courseId="@Model.CourseId" class="btn btn-sm btn-outline-warning">Edit</a>
                            <form asp-action="DeleteQuestion" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@q.Id" />
                                <input type="hidden" name="courseId" value="@Model.CourseId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this question?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                    <ul class="list-unstyled small mb-0 ps-3">
                        <li class="@(q.CorrectOption == "A" ? "text-success fw-bold" : "")">A) @q.OptionA @(q.CorrectOption == "A" ? "✓" : "")</li>
                        <li class="@(q.CorrectOption == "B" ? "text-success fw-bold" : "")">B) @q.OptionB @(q.CorrectOption == "B" ? "✓" : "")</li>
                        <li class="@(q.CorrectOption == "C" ? "text-success fw-bold" : "")">C) @q.OptionC @(q.CorrectOption == "C" ? "✓" : "")</li>
                        <li class="@(q.CorrectOption == "D" ? "text-success fw-bold" : "")">D) @q.OptionD @(q.CorrectOption == "D" ? "✓" : "")</li>
                    </ul>
                </div>
            }
        }
    </div>
</div>

<!-- Add new question -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0">Add New Question</h5>
    </div>
    <div class="card-body">
        <form asp-action="AddQuestion" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="QuizId" value="@Model.Id" />
            <input type="hidden" name="courseId" value="@Model.CourseId" />

            <div class="mb-3">
                <label class="form-label">Question</label>
                <input type="text" name="QuestionText" class="form-control" placeholder="e.g. What is the capital of Bangladesh?" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Option A</label>
                    <input type="text" name="OptionA" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Option B</label>
                    <input type="text" name="OptionB" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Option C</label>
                    <input type="text" name="OptionC" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Option D</label>
                    <input type="text" name="OptionD" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Correct Option</label>
                <select name="CorrectOption" class="form-select" style="max-width:200px;">
                    <option value="">-- Pick correct --</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary">+ Add Question</button>
        </form>
    </div>
</div>