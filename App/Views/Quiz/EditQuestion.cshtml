@model BLL.DTOs.QuestionDTO
@{
    ViewData["Title"] = "Edit Question";
    int courseId = (int)ViewBag.CourseId!;
    bool IsCorrect(string letter) => Model.CorrectOption == letter;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="mb-4">Edit Question</h1>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="EditQuestion" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="QuizId" value="@Model.QuizId" />
                    <input type="hidden" name="courseId" value="@courseId" />

                    <div class="mb-3">
                        <label class="form-label">Question</label>
                        <input type="text" name="QuestionText" value="@Model.QuestionText" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Option A</label>
                            <input type="text" name="OptionA" value="@Model.OptionA" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Option B</label>
                            <input type="text" name="OptionB" value="@Model.OptionB" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Option C</label>
                            <input type="text" name="OptionC" value="@Model.OptionC" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Option D</label>
                            <input type="text" name="OptionD" value="@Model.OptionD" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Correct Option</label>
                        <select name="CorrectOption" class="form-select" style="max-width:200px;">
                            <option value="A" selected="@IsCorrect("A")">A</option>
                            <option value="B" selected="@IsCorrect("B")">B</option>
                            <option value="C" selected="@IsCorrect("C")">C</option>
                            <option value="D" selected="@IsCorrect("D")">D</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Manage" asp-route-id="@courseId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>