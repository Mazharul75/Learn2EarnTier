@model IEnumerable<BLL.DTOs.EnrollmentDTO>
@{
    ViewData["Title"] = "My Courses";
    var completedIds = ViewBag.CompletedCourseIds as HashSet<int> ?? new HashSet<int>();
    var attemptedIds = ViewBag.AttemptedCourseIds as HashSet<int> ?? new HashSet<int>();
}

<div class="mb-4">
    <h1 class="mb-1">My Enrolled Courses</h1>
    <p class="text-muted">Study materials, complete tasks, and take quizzes.</p>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">📚</div>
            <h5 class="text-muted">You haven't enrolled in any courses yet</h5>
            <p class="text-muted small mb-3">Browse the catalog and pick something that interests you.</p>
            <a asp-controller="Learner" asp-action="BrowseCourses" class="btn btn-primary">Browse Catalog</a>
        </div>
    </div>
}
else
{
    <p class="text-muted small mb-3">You're enrolled in <strong>@Model.Count()</strong> course(s).</p>
    <div class="row g-3">
        @foreach (var e in Model)
        {
            bool isCompleted = completedIds.Contains(e.CourseId);
            bool quizAttempted = attemptedIds.Contains(e.CourseId);

            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-light text-dark border">@e.CourseDifficulty</span>
                            <small class="text-muted">Enrolled @e.EnrolledAt.ToString("dd MMM yyyy")</small>
                        </div>

                        <h5 class="card-title">@e.CourseTitle</h5>
                        <p class="text-muted small mb-3">by @e.InstructorName</p>

                        <p class="card-text text-muted small">
                            @(e.CourseDescription != null && e.CourseDescription.Length > 130
                                                ? e.CourseDescription.Substring(0, 130) + "..."
                                                : e.CourseDescription)
                        </p>

                        <!-- Action buttons grouped properly -->
                        <div class="border-top pt-3 mt-2">
                            <!-- Row 1: Study + completion -->
                            <div class="d-flex gap-2 flex-wrap mb-2">
                                @if (!string.IsNullOrEmpty(e.CourseContentLink))
                                {
                                    <a href="@e.CourseContentLink" target="_blank" rel="noopener" class="btn btn-sm btn-outline-success">
                                        📚 Study Materials
                                    </a>

                                    @if (isCompleted)
                                    {
                                        <span class="badge bg-success align-self-center">✓ Studied</span>
                                    }
                                    else
                                    {
                                        <form asp-action="MarkMaterialComplete" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="courseId" value="@e.CourseId" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Mark as Studied</button>
                                        </form>
                                    }
                                }
                                else
                                {
                                    <small class="text-muted">No study materials yet</small>
                                }
                            </div>

                            <!-- Row 2: Tasks + Quiz -->
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-controller="Task" asp-action="MyTasks" asp-route-id="@e.CourseId" class="btn btn-sm btn-outline-primary">
                                    📋 Tasks
                                </a>
                                @if (quizAttempted)
                                {
                                    <span class="badge bg-secondary align-self-center">Quiz attempted</span>
                                }
                                else
                                {
                                    <a asp-controller="Quiz" asp-action="Take" asp-route-id="@e.CourseId" class="btn btn-sm btn-primary">
                                        📝 Take Quiz
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}