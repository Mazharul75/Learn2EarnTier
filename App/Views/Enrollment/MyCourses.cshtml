@model IEnumerable<BLL.DTOs.EnrollmentDTO>

@{
    ViewData["Title"] = "My Courses";
}

<h1>My Enrolled Courses</h1>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-@TempData["Class"]">@TempData["Msg"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        You haven't enrolled in any courses yet.
        <a asp-controller="Learner" asp-action="BrowseCourses">Browse the catalog</a>
        to find one.
    </div>
}
else
{
    <p class="text-muted">@Model.Count() course(s)</p>
    <div class="row">
        @foreach (var e in Model)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@e.CourseTitle</h5>
                        <h6 class="card-subtitle mb-2 text-muted">by @e.InstructorName</h6>
                        <span class="badge bg-secondary mb-2">@e.CourseDifficulty</span>
                        <p class="card-text">
                            @(e.CourseDescription != null && e.CourseDescription.Length > 150
                                                ? e.CourseDescription.Substring(0, 150) + "..."
                                                : e.CourseDescription)
                        </p>
                    </div>
                    <div class="card-footer">
                        <small class="text-muted">Enrolled @e.EnrolledAt.ToString("dd MMM yyyy")</small>
                        @{
                            var completedIds = ViewBag.CompletedCourseIds as HashSet<int> ?? new HashSet<int>();
                            bool isCompleted = completedIds.Contains(e.CourseId);
                        }

                        <div class="mt-2 d-flex gap-2 flex-wrap">
                            @if (!string.IsNullOrEmpty(e.CourseContentLink))
                            {
                                <a href="@e.CourseContentLink" target="_blank" rel="noopener" class="btn btn-sm btn-success">📚 Study Materials</a>
                            }

                            @if (isCompleted)
                            {
                                <span class="badge bg-secondary align-self-center">✓ Studied</span>
                            }
                            else if (!string.IsNullOrEmpty(e.CourseContentLink))
                            {
                                <form asp-action="MarkMaterialComplete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courseId" value="@e.CourseId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Mark as Studied</button>
                                </form>
                            }
                            <a asp-controller="Task" asp-action="MyTasks" asp-route-id="@e.CourseId" class="btn btn-sm btn-outline-primary">Tasks</a>
                            <a asp-controller="Quiz" asp-action="Take" asp-route-id="@e.CourseId" class="btn btn-sm btn-primary">Take Quiz</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <a asp-controller="Learner" asp-action="Dashboard" class="btn btn-link">← Back to Dashboard</a>
    <a asp-controller="Learner" asp-action="BrowseCourses" class="btn btn-link">Browse more courses</a>
</div>