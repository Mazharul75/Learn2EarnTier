@{
    ViewData["Title"] = "Manage Tasks";
    var course = ViewBag.Course as BLL.DTOs.CourseDTO;
    var tasks = ViewBag.Tasks as List<BLL.DTOs.CourseTaskDTO> ?? new List<BLL.DTOs.CourseTaskDTO>();
    var pending = ViewBag.PendingSubmissions as List<BLL.DTOs.TaskSubmissionDTO> ?? new List<BLL.DTOs.TaskSubmissionDTO>();
}

<h1>Manage Tasks</h1>
<p class="text-muted">Course: <strong>@course?.Title</strong></p>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-@TempData["Class"]">@TempData["Msg"]</div>
}

<hr />

<h3>Existing Tasks (@tasks.Count)</h3>

@if (!tasks.Any())
{
    <p class="text-muted">No tasks yet.</p>
}
else
{
    <div class="row">
        @foreach (var t in tasks)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5>@t.Title</h5>
                        <p class="text-muted">@t.Description</p>
                        <small class="text-muted">Created @t.CreatedAt.ToString("dd MMM yyyy")</small>
                        <form asp-action="DeleteTask" method="post" class="mt-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <input type="hidden" name="courseId" value="@course?.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete this task?');">
                                Delete Task
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<hr />

<h3>Add New Task</h3>
<form asp-action="AddTask" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="CourseId" value="@course?.Id" />

    <div class="mb-3">
        <label class="form-label">Task Title</label>
        <input type="text" name="Title" class="form-control" placeholder="e.g. Build a calculator" />
    </div>

    <div class="mb-3">
        <label class="form-label">Description (optional)</label>
        <textarea name="Description" rows="3" class="form-control" placeholder="What should the learner do?"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Add Task</button>
</form>

<hr />

<h3>Pending Submissions (@pending.Count)</h3>

@if (!pending.Any())
{
    <p class="text-muted">No submissions awaiting review.</p>
}
else
{
    @foreach (var s in pending)
    {
        <div class="card mb-3 border-warning">
            <div class="card-body">
                <h6><strong>@s.LearnerName</strong> submitted <em>@s.TaskTitle</em></h6>
                <p>
                    <a href="@s.SubmissionLink" target="_blank" rel="noopener" class="btn btn-sm btn-info">View Submission</a>
                    <small class="text-muted ms-2">Submitted @s.SubmittedAt.ToString("dd MMM yyyy HH:mm")</small>
                </p>

                <form asp-action="Review" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SubmissionId" value="@s.Id" />
                    <input type="hidden" name="courseId" value="@course?.Id" />

                    <div class="mb-2">
                        <label class="form-label small">Feedback (optional)</label>
                        <textarea name="Feedback" rows="2" class="form-control"></textarea>
                    </div>
                    <button type="submit" name="Status" value="Approved" class="btn btn-sm btn-success">Approve</button>
                    <button type="submit" name="Status" value="Rejected" class="btn btn-sm btn-danger">Reject</button>
                </form>
            </div>
        </div>
    }
}

<a asp-controller="Course" asp-action="Index" class="btn btn-link">← Back to My Courses</a>