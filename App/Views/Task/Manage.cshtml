@{
    ViewData["Title"] = "Manage Tasks";
    var course = ViewBag.Course as BLL.DTOs.CourseDTO;
    var tasks = ViewBag.Tasks as List<BLL.DTOs.CourseTaskDTO> ?? new List<BLL.DTOs.CourseTaskDTO>();
    var pending = ViewBag.PendingSubmissions as List<BLL.DTOs.TaskSubmissionDTO> ?? new List<BLL.DTOs.TaskSubmissionDTO>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Manage Tasks</h1>
        <p class="text-muted mb-0">Course: <strong>@course?.Title</strong></p>
    </div>
    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<!-- Existing tasks -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">Existing Tasks <span class="badge bg-secondary">@tasks.Count</span></h5>
    </div>
    <div class="card-body">
        @if (!tasks.Any())
        {
            <p class="text-muted text-center my-3">No tasks yet. Add the first one below.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var t in tasks)
                {
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <h6 class="mb-1">@t.Title</h6>
                            @if (!string.IsNullOrEmpty(t.Description))
                            {
                                <p class="text-muted small mb-2">@t.Description</p>
                            }
                            <small class="text-muted d-block mb-2">Created @t.CreatedAt.ToString("dd MMM yyyy")</small>
                            <form asp-action="DeleteTask" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.Id" />
                                <input type="hidden" name="courseId" value="@course?.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this task?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Add new task -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">Add New Task</h5>
    </div>
    <div class="card-body">
        <form asp-action="AddTask" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CourseId" value="@course?.Id" />

            <div class="mb-3">
                <label class="form-label">Task Title</label>
                <input type="text" name="Title" class="form-control" placeholder="e.g. Build a calculator" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description (optional)</label>
                <textarea name="Description" rows="3" class="form-control" placeholder="What should the learner do?"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">+ Add Task</button>
        </form>
    </div>
</div>

<!-- Pending submissions -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0">Pending Submissions <span class="badge bg-warning text-dark">@pending.Count</span></h5>
    </div>
    <div class="card-body">
        @if (!pending.Any())
        {
            <p class="text-muted text-center my-3">No submissions awaiting review.</p>
        }
        else
        {
            @foreach (var s in pending)
            {
                <div class="border-warning border rounded p-3 mb-3" style="border-left-width:4px !important;">
                    <h6 class="mb-1"><strong>@s.LearnerName</strong> submitted <em>@s.TaskTitle</em></h6>
                    <p class="small mb-2">
                        <a href="@s.SubmissionLink" target="_blank" rel="noopener" class="btn btn-sm btn-outline-info">📎 View Submission</a>
                        <span class="text-muted ms-2">@s.SubmittedAt.ToString("dd MMM yyyy, HH:mm")</span>
                    </p>

                    <form asp-action="Review" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SubmissionId" value="@s.Id" />
                        <input type="hidden" name="courseId" value="@course?.Id" />

                        <div class="mb-2">
                            <label class="form-label small text-muted">Feedback (optional)</label>
                            <textarea name="Feedback" rows="2" class="form-control form-control-sm"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" name="Status" value="Approved" class="btn btn-sm btn-success">✓ Approve</button>
                            <button type="submit" name="Status" value="Rejected" class="btn btn-sm btn-danger">✗ Reject</button>
                        </div>
                    </form>
                </div>
            }
        }
    </div>
</div>