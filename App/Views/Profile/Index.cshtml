@model IEnumerable<BLL.DTOs.TaskSubmissionDTO>
@if (TempData["Msg"] != null)
{
    <div class="alert alert-info">@TempData["Msg"]</div>
}
<h2>Review Student Tasks</h2>
<table class="table table-bordered">
    <tr>
        <th>Learner Name</th>
        <th>Task Title</th>
        <th>Link</th>
        <th>Action</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.LearnerName</td>
            <td>@item.TaskTitle</td>
            <td><a href="@item.SubmissionLink" target="_blank">View Work</a></td>
            <td>
                <form method="post" action="/Task/ReviewSubmission" style="display:inline;">
                    <input type="hidden" name="Id" value="@item.Id" />
                    <button type="submit" name="Status" value="Approved" class="btn btn-sm btn-success">Approve</button>
                    <button type="submit" name="Status" value="Rejected" class="btn btn-sm btn-danger">Reject</button>
                </form>
            </td>
        </tr>
    }
</table>