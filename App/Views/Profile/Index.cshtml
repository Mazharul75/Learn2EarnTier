@model BLL.DTOs.ProfileDTO
@{
    ViewData["Title"] = "My Profile";
}

<h1>My Profile</h1>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-@TempData["Class"]">@TempData["Msg"]</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Account Info</h5>
                <dl class="row">
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8"><span class="badge bg-info">@Model.UserTypeName</span></dd>

                    <dt class="col-sm-4">Member since</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Edit Profile</h5>
                <form method="post" asp-action="Index">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="Name" value="@Model.Name" class="form-control" />
                        <small class="text-muted">Email and role cannot be changed.</small>
                    </div>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>