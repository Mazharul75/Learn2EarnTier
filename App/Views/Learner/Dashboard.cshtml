@{
    ViewData["Title"] = "Learner Dashboard";
}

<div class="row">
    <div class="col">
        <h2>Welcome, @ViewBag.UserName!</h2>
        <p class="lead">This is your learner dashboard.</p>
        <p>From here you'll be able to browse courses, take quizzes, and track your progress.</p>
        <hr />
        <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger">Logout</a>
    </div>
</div>