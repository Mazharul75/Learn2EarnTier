@model BLL.DTOs.LoginDTO
@{
    ViewData["Title"] = "Login";
}

<h2 class="mb-4">Login</h2>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-@TempData["Class"]">@TempData["Msg"]</div>
}

<form method="post" asp-controller="Auth" asp-action="Login">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="text" name="Email" value="@Model.Email" placeholder="Email" class="form-control" />
        <span class="text-danger">@Html.ValidationMessage("Email")</span>
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="Password" placeholder="Password" class="form-control" />
        <span class="text-danger">@Html.ValidationMessage("Password")</span>
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
    <a asp-controller="Auth" asp-action="Registration" class="btn btn-link">Register instead</a>
</form>