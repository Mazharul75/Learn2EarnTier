@model BLL.DTOs.LoginDTO
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body p-4 p-md-5">
                <h2 class="mb-1">Welcome back</h2>
                <p class="text-muted mb-4">Sign in to continue your learning journey.</p>

                <form method="post" asp-controller="Auth" asp-action="Login">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" value="@Model.Email" class="form-control form-control-lg" placeholder="you@example.com" autofocus />
                        <span class="text-danger small">@Html.ValidationMessage("Email")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="Password" class="form-control form-control-lg" placeholder="••••••••" />
                        <span class="text-danger small">@Html.ValidationMessage("Password")</span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Sign In</button>
                </form>

                <div class="text-center text-muted">
                    Don't have an account?
                    <a asp-controller="Auth" asp-action="Registration" class="text-decoration-none">Register here</a>
                </div>
            </div>
        </div>
    </div>
</div>