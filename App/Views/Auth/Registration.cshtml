@model BLL.DTOs.RegistrationDTO
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm mt-4">
            <div class="card-body p-4 p-md-5">
                <h2 class="mb-1">Create your account</h2>
                <p class="text-muted mb-4">Join Learn2Earn — pick a role and start in seconds.</p>

                <form method="post" asp-controller="Auth" asp-action="Registration">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="Name" value="@Model.Name" class="form-control" placeholder="e.g. Tanvir Ahmed" />
                        <span class="text-danger small">@Html.ValidationMessage("Name")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" value="@Model.Email" class="form-control" placeholder="you@example.com" />
                        <span class="text-danger small">@Html.ValidationMessage("Email")</span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Password</label>
                            <input type="password" name="Password" class="form-control" placeholder="At least 6 characters" />
                            <span class="text-danger small">@Html.ValidationMessage("Password")</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Confirm Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                            <span class="text-danger small">@Html.ValidationMessage("ConfirmPassword")</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">I am a</label>
                        <select name="UserTypeId" class="form-select">
                            <option value="0" disabled selected>-- Select Role --</option>
                            @foreach (var t in (List<DAL.EF.Tables.UserType>)ViewBag.UserTypes)
                            {
                                <option value="@t.Id" selected="@(Model.UserTypeId == t.Id)">@t.Name</option>
                            }
                        </select>
                        <span class="text-danger small">@Html.ValidationMessage("UserTypeId")</span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Create Account</button>
                </form>

                <div class="text-center text-muted">
                    Already have an account?
                    <a asp-controller="Auth" asp-action="Login" class="text-decoration-none">Sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>