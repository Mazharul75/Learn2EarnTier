@model IEnumerable<BLL.DTOs.CourseDTO>
@{
    ViewData["Title"] = "My Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">My Courses</h1>
        <p class="text-muted mb-0">Manage everything you teach.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Create New Course</a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">📖</div>
            <h5 class="text-muted">No courses yet</h5>
            <p class="text-muted small mb-3">Click <em>Create New Course</em> to publish your first one.</p>
            <a asp-action="Create" class="btn btn-primary">Create Your First Course</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Difficulty</th>
                        <th>Capacity</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Title</strong>
                                @if (!string.IsNullOrEmpty(item.PrerequisiteTitle))
                                {
                                    <br />
                                    <small class="text-muted">Requires: @item.PrerequisiteTitle</small>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark border">@item.Difficulty</span></td>
                            <td>
                                @if (item.MaxCapacity > 0)
                                {
                                    <small>@item.MaxCapacity max</small>
                                }
                                else
                                {
                                    <small class="text-muted">Unlimited</small>
                                }
                            </td>
                            <td><small>@item.CreatedAt.ToString("dd MMM yyyy")</small></td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Edit">✏️Edit</a>
                                    <a asp-controller="Quiz" asp-action="Manage" asp-route-id="@item.Id" class="btn btn-outline-info" title="Quiz">📝Quiz</a>
                                    <a asp-controller="Task" asp-action="Manage" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Tasks">📋Tasks</a>
                                    <a asp-action="Students" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Students">👥Students</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">🗑️Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}