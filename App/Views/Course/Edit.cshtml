@model BLL.DTOs.CourseDTO

@{
    ViewData["Title"] = "Edit Course";

    bool CheckDifficulty(string val)
    {
        return Model.Difficulty == val;
    }
}

<h1>Edit Course</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Difficulty" class="form-label"></label>
                <select name="Difficulty" class="form-select">
                    <option value="">-- Select Difficulty --</option>
                    <option value="Beginner" selected="@CheckDifficulty("Beginner")">Beginner</option>
                    <option value="Intermediate" selected="@CheckDifficulty("Intermediate")">Intermediate</option>
                    <option value="Advanced" selected="@CheckDifficulty("Advanced")">Advanced</option>
                </select>
                <span asp-validation-for="Difficulty" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ContentLink" class="form-label">Course Content Link (Google Drive, YouTube, etc.)</label>
                <input asp-for="ContentLink" class="form-control" placeholder="https://drive.google.com/..." />
                <span asp-validation-for="ContentLink" class="text-danger"></span>
                <small class="text-muted">Optional — paste a link to your slides, videos, or other materials.</small>
            </div>
            <div class="mb-3">
                <label asp-for="PrerequisiteId" class="form-label">Prerequisite Course (optional)</label>
                <select asp-for="PrerequisiteId" class="form-select">
                    <option value="">-- None --</option>
                    @foreach (var c in (List<BLL.DTOs.CourseDTO>)ViewBag.AvailableCourses)
                    {
                        <option value="@c.Id" selected="@(Model.PrerequisiteId == c.Id)">@c.Title</option>
                    }
                </select>
                <small class="text-muted">Learners must pass this course's quiz before enrolling here.</small>
            </div>
            <div class="mb-3">
                <label asp-for="MaxCapacity" class="form-label">Max Capacity (0 = unlimited)</label>
                <input asp-for="MaxCapacity" class="form-control" type="number" min="0" max="1000" />
                <span asp-validation-for="MaxCapacity" class="text-danger"></span>
                <small class="text-muted">Maximum number of learners who can enroll. Set 0 for no limit.</small>
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>