@model List<BLL.DTOs.EnrollmentDTO>
@{
    ViewData["Title"] = "Enrolled Students";
    var course = ViewBag.Course as BLL.DTOs.CourseDTO;
}

<h1>Enrolled Students</h1>
<p class="text-muted">Course: <strong>@course?.Title</strong></p>

@if (!Model.Any())
{
    <div class="alert alert-info">No students enrolled yet.</div>
}
else
{
    <p class="text-muted">@Model.Count student(s) enrolled.</p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Enrolled On</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.LearnerName</td>
                    <td>@s.LearnerEmail</td>
                    <td>@s.EnrolledAt.ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-link">← Back to My Courses</a>