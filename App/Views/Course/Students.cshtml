@model List<BLL.DTOs.EnrollmentDTO>
@{
    ViewData["Title"] = "Enrolled Students";
    var course = ViewBag.Course as BLL.DTOs.CourseDTO;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Enrolled Students</h1>
        <p class="text-muted mb-0">Course: <strong>@course?.Title</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">👥</div>
            <h5 class="text-muted">No students enrolled yet</h5>
            <p class="text-muted small">Once learners enroll, they'll appear here.</p>
        </div>
    </div>
}
else
{
    <p class="text-muted small mb-3"><strong>@Model.Count</strong> student(s) enrolled.</p>
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th class="text-end">Enrolled On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><strong>@s.LearnerName</strong></td>
                            <td class="text-muted">@s.LearnerEmail</td>
                            <td class="text-end text-muted"><small>@s.EnrolledAt.ToString("dd MMM yyyy")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}