@model BLL.DTOs.CourseDTO

@{
    ViewData["Title"] = "Delete Course";
}

<h1>Delete Course</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this course? This action cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Difficulty</dt>
    <dd class="col-sm-9">@Model.Difficulty</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Created</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
</dl>

<form method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" name="Decision" value="Yes" class="btn btn-danger">Yes, Delete</button>
    <button type="submit" name="Decision" value="No" class="btn btn-secondary">No, Cancel</button>
</form>